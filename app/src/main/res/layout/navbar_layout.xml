<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/lythzNavbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/imgbtnHome"
            android:layout_width="90dp"
            android:layout_height="80dp"
            android:backgroundTint="#01FFFFFF"
            android:contentDescription="Botão para página principal"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/home" />

        <ImageButton
            android:id="@+id/imgbtnCalendário"
            android:layout_width="90dp"
            android:layout_height="80dp"
            android:backgroundTint="#00FFFFFF"
            android:contentDescription="Botão para calendário"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/calendario" />

        <ImageButton
            android:id="@+id/imgbtnNoticias"
            android:layout_width="90dp"
            android:layout_height="80dp"
            android:backgroundTint="#00FFFFFF"
            android:contentDescription="Botão para aba notícias"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/noticias" />

        <ImageButton
            android:id="@+id/imgbtnUsuario"
            android:layout_width="90dp"
            android:layout_height="80dp"
            android:backgroundTint="#00FFFFFF"
            android:contentDescription="Botão para área de usuário"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/usuario" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
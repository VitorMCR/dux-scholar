<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NewsActivity">

    <View
        android:id="@+id/viewServCabecalhoDivider4"
        android:layout_width="200dp"
        android:layout_height="1dp"
        android:background="#000"
        tools:layout_editor_absoluteX="21dp"
        tools:layout_editor_absoluteY="62dp"
        tools:ignore="MissingConstraints" />

    <TextView
        android:id="@+id/txtServCabecalho2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:text="Notícias"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="21dp"
        tools:layout_editor_absoluteY="35dp" />

    <ImageButton
        android:id="@+id/imgbtnUsuario"
        android:layout_width="90dp"
        android:layout_height="80dp"
        android:backgroundTint="#00FFFFFF"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/usuário"
        tools:ignore="MissingConstraints,SpeakableTextPresentCheck"
        tools:layout_editor_absoluteX="301dp"
        tools:layout_editor_absoluteY="631dp" />

    <ImageButton
        android:id="@+id/imgbtnCalendário"
        android:layout_width="90dp"
        android:layout_height="80dp"
        android:backgroundTint="#00FFFFFF"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/calendario"
        tools:ignore="MissingConstraints,SpeakableTextPresentCheck"
        tools:layout_editor_absoluteX="21dp"
        tools:layout_editor_absoluteY="633dp" />

    <ImageButton
        android:id="@+id/imgbtnHome"
        android:layout_width="90dp"
        android:layout_height="80dp"
        android:backgroundTint="#01FFFFFF"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/home"
        tools:ignore="MissingConstraints,SpeakableTextPresentCheck"
        tools:layout_editor_absoluteX="113dp"
        tools:layout_editor_absoluteY="633dp" />

    <ImageButton
        android:id="@+id/imgbtnNoticias"
        android:layout_width="90dp"
        android:layout_height="80dp"
        android:backgroundTint="#00FFFFFF"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/notícias"
        tools:ignore="MissingConstraints,SpeakableTextPresentCheck"
        tools:layout_editor_absoluteX="207dp"
        tools:layout_editor_absoluteY="633dp" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="270dp"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/linha"
        tools:layout_editor_absoluteX="70dp"
        tools:layout_editor_absoluteY="627dp"
        tools:ignore="MissingConstraints" />

    <ImageButton
        android:id="@+id/imgbtnDuque"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:backgroundTint="#00FFFFFF"
        android:scaleType="fitCenter"
        app:srcCompat="@drawable/DuqueIcon"
        tools:ignore="MissingConstraints,SpeakableTextPresentCheck"
        tools:layout_editor_absoluteX="321dp"
        tools:layout_editor_absoluteY="532dp" />

    <ListView
        android:id="@+id/listviewNotivias"
        android:layout_width="360dp"
        android:layout_height="460dp"
        tools:layout_editor_absoluteX="21dp"
        tools:layout_editor_absoluteY="62dp"
        tools:ignore="MissingConstraints" />

</androidx.constraintlayout.widget.ConstraintLayout>